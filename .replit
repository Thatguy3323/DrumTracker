modules = ["dotnet-7.0", "web", "python-3.11", "nodejs-20"]
[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"
integrations = ["python_database:1.0.0"]

[nix]
channel = "stable-25_05"
packages = ["ffmpeg-full", "libsndfile", "libxcrypt", "pkg-config", "xsimd"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start application"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "(cd backend && python3 -m uvicorn main:app --host 127.0.0.1 --port 8080) & (cd frontend && npm run dev)"
waitForPort = 5000

[[workflows.workflow.tasks]]
task = "packager.installForLanguage"
args = "dotnet"

[[workflows.workflow.tasks]]
task = "packager.installForLanguage"
args = "python3"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "artifacts/mockup-sandbox: Component Preview Server"
author = "agent"
mode = "sequential"

[workflows.workflow.metadata]
outputType = "webview"
artifactId = "artifacts/mockup-sandbox"
isCanvasWorkflow = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
cwd = "./artifacts/mockup-sandbox"
waitForPort = 23636
ensurePreviewReachable = "/"
router = "path"

[workflows.workflow.tasks.env]
PORT = "23636"
BASE_PATH = "/__mockup/"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 23636
externalPort = 3000

[deployment]
deploymentTarget = "autoscale"
publicDir = "."
run = ["bash", "-c", "cd backend && python3 -m uvicorn main:app --host 0.0.0.0 --port 5000"]
build = ["bash", "-c", "cd frontend && npm install && npm run build"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 120000
