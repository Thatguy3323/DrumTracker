<Application x:Class="DrumTracker.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Global Resources -->
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Colors.xaml"/>
                <ResourceDictionary Source="Resources/Styles.xaml"/>
                <ResourceDictionary Source="Resources/Brushes.xaml"/>
                <ResourceDictionary Source="Resources/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Default Fonts -->
            <FontFamily x:Key="FontFamily.Primary">Segoe UI</FontFamily>
            <FontFamily x:Key="FontFamily.Mono">Consolas</FontFamily>

            <!-- Base Font Sizes -->
            <sys:Double x:Key="FontSize.Small">11</sys:Double>
            <sys:Double x:Key="FontSize.Normal">12</sys:Double>
            <sys:Double x:Key="FontSize.Medium">14</sys:Double>
            <sys:Double x:Key="FontSize.Large">16</sys:Double>
            <sys:Double x:Key="FontSize.Title">20</sys:Double>
            <sys:Double x:Key="FontSize.Header">28</sys:Double>

            <!-- Spacing Defaults -->
            <Thickness x:Key="Spacing.Small">4</Thickness>
            <Thickness x:Key="Spacing.Normal">8</Thickness>
            <Thickness x:Key="Spacing.Medium">16</Thickness>
            <Thickness x:Key="Spacing.Large">24</Thickness>

            <!-- Shadows -->
            <DropShadowEffect x:Key="Shadow.Small" BlurRadius="4" ShadowDepth="2" Opacity="0.3"/>
            <DropShadowEffect x:Key="Shadow.Medium" BlurRadius="8" ShadowDepth="4" Opacity="0.4"/>
            <DropShadowEffect x:Key="Shadow.Large" BlurRadius="12" ShadowDepth="6" Opacity="0.5"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
